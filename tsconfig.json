{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["esnext", "dom"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": ["src/"],
  "exclude": ["node_modules", "dist"]
}
