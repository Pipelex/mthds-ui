{
  "name": "@pipelex/mthds-ui",
  "version": "0.1.0",
  "description": "Shared graph rendering logic for MTHDS method visualization",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pipelex/mthds-ui.git"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./shiki": {
      "import": "./dist/shiki/index.js",
      "types": "./dist/shiki/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "prepare": "tsup",
    "build": "tsup",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test"
  },
  "peerDependencies": {
    "dagre": "^0.8.5",
    "@types/dagre": "^0.7.54",
    "shiki": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "@types/dagre": {
      "optional": true
    },
    "shiki": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/dagre": "^0.7.54",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "shiki": "^3.22.0",
    "tsup": "^8.5.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.35.1",
    "vitest": "^4.1.0"
  }
}
